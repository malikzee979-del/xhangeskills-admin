{
  "kind": "collectionType",
  "collectionName": "service_requests",
  "info": {
    "singularName": "service-request",
    "pluralName": "service-requests",
    "displayName": "Service Request",
    "name": "service-request",
    "description": "ServiceRequest - stores booking or service requests between users"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": false
  },
  "attributes": {
    "requestDetails": {
      "type": "text",
      "required": true
    },
    "requestedTime": {
      "type": "string"
    },
    "duration": {
      "type": "integer",
      "required": true
    },
    "serviceMode": {
      "type": "enumeration",
      "enum": ["REMOTE", "ONSITE", "HYBRID"],
      "required": true
    },
    "serviceLocation": {
      "type": "text"
    },
    "respondedAt": {
      "type": "datetime"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "accepted", "rejected", "completed"],
      "default": "pending"
    },
    "responseNote": {
      "type": "text"
    },
    "expiresAt": {
      "type": "datetime"
    },
    "skill": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::skill.skill",
      "inversedBy": "serviceRequests"
    },
    "requester": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "provider": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "bookingRequest"
    },
    "reports": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::report.report",
      "mappedBy": "bookingRequest"
    },
    "createdBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "admin::user"
    },
    "updatedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "admin::user"
    }
  }
}
